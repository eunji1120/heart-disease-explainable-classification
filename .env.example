# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# MySQL connection for the project (least-privilege account)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=heart_disease_project
MYSQL_USER=heart_project_user
MYSQL_PASSWORD=replace-me

# Path to the mysql client binary (only needed while brew has not yet symlinked it to PATH).
# Once `which mysql` resolves, this can be removed.
MYSQL_BIN=/usr/local/Cellar/mysql/8.3.0_1/bin/mysql
